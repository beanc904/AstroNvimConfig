#!/bin/bash

set -euo pipefail

source "$COLOR_SCHEME_INCLUDE"

CONFIG_DIR="$HOME/.config"

usage() {
  error "Usage: configsync [zed|nvim] [push|pull|stash]"
  exit 1
}

run_git_action() {
  local app="$1"
  case "$app" in
    zed)
      app_name="Zed"
      ;;
    nvim)
      app_name="Nvim"
      ;;
  esac
  local action="$2"
  local repo="$CONFIG_DIR/$app"

  if [[ ! -d "$repo" ]]; then
    error "Config directory not found: $repo"
    exit 1
  fi

  cd "$repo"

  case "$action" in
    push)
      git add .

      # Avoid commit failed when there is no commit
      if ! git diff --cached --quiet; then
        case "$OSTYPE" in
          linux-gnu*)
            git commit -m "Auto Sync (arch): $(date '+%Y-%m-%d %T')"
            ;;
          darwin*)
            git commit -m "Auto Sync (mac): $(date '+%Y-%m-%d %T')"
            ;;
          *)
            echo "Unknown OS type: $OSTYPE"
            ;;
        esac
      fi

      if git push origin main; then
        success "$app_name settings pushed to remote repository"
      else
        error "Something went wrong during $app_name push process"
      fi
      ;;

    pull)
      if git pull origin main; then
        success "$app_name settings pulled from remote repository"
      else
        error "Something went wrong during $app_name pull process"
      fi
      ;;

    stash)
      if git stash; then
        success "$app_name settings stashed locally"
      else
        error "Something went wrong during $app_name stash process"
      fi
      ;;

    *)
      usage
      ;;
  esac
}

[[ $# -ne 2 ]] && usage

APP="$1"
ACTION="$2"

case "$APP" in
  zed|nvim)
    run_git_action "$APP" "$ACTION"
    ;;
  *)
    usage
    ;;
esac
